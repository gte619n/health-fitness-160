# Local Auth.js + backend config.
# Copy to .env.local and fill in. Auth.js will refuse to start without AUTH_SECRET.

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# OAuth client credentials from GCP Console (the "web" client type).
# In production these come from Secret Manager (oauth-web-client-id,
# oauth-web-client-secret) via the Cloud Run service config.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Backend service base URL. Local Spring Boot defaults to :8080.
BACKEND_URL=http://localhost:8080
